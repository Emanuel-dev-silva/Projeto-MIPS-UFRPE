// Instruções usadas para testar o processador MIPS.
// Aqui estão algumas das instruções pedidas pelo professor,
// incluindo operações tipo R, tipo I, tipo J, memória,
// branch, jump, jal e jr.

00100000000010010000000000001010 // addi $t1, $zero, 10
00110001001010100000000000000011 // andi $t2, $t1, 3
00110101010010110000000000001000 // ori  $t3, $t2, 8
00111001011011000000000000001111 // xori $t4, $t3, 15
00101001100011010000000000001010 // slti $t5, $t4, 10
00101101100011100000000000000011 // sltiu $t6, $t4, 3
00111100000011110001001000110100 // lui $t7, 0x1234
00010101101011100000000000000010 // bne $t5, $t6, 2

00100000000100000000000001100011 // addi $s0, $zero, 99
00100000000100010000000001100100 // addi $s1, $zero, 100

00100000000010000000000000001111 // addi $t0, $zero, 15
10101100000010000000000000000000 // sw $t0, 0($zero)
10001100000100100000000000000000 // lw $s2, 0($zero)

00001100000000000000000000010000 // jal 16
00100000000100110000000001111011 // addi $s3, $zero, 123
00001000000000000000000000010010 // j 18
00100000000101010000000001001101 // addi $s5, $zero, 77
00000011111000000000000000001000 // jr $ra
00000000000000000000000000100000 // add $zero, $zero, $zero
